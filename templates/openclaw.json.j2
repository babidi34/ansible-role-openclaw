{
  "agents": {
    "defaults": {
      "workspace": "{{ openclaw_workspace_dir }}",
      "sandbox": {
        "mode": "{{ openclaw_sandbox_mode }}",
        "workspaceAccess": "{{ openclaw_sandbox_workspace_access }}"
      }{% if openclaw_model_primary | length > 0 %},
      "model": {
        "primary": "{{ openclaw_model_primary }}"{% if openclaw_model_fallbacks | length > 0 %},
        "fallbacks": {{ openclaw_model_fallbacks | to_nice_json }}{% endif %}
      }{% endif %}{% if openclaw_models_allowlist | length > 0 %},
      "models": {{ openclaw_models_allowlist | to_nice_json }}{% endif %}
    }
  },
  "gateway": {
    "mode": "{{ openclaw_gateway_mode }}",
    "bind": "{{ openclaw_gateway_bind }}",
    "port": {{ openclaw_gateway_port }}{% if openclaw_gateway_password | length > 0 %},
    "auth": {
      "mode": "password",
      "password": "{{ openclaw_gateway_password }}"
    }{% elif openclaw_gateway_auth_token | length > 0 %},
    "auth": {
      "mode": "token",
      "token": "${{ openclaw_gateway_auth_env }}"
    }{% endif %}{% if openclaw_tailscale_enabled %},
    "tailscale": {
      "mode": "{{ openclaw_tailscale_mode }}",
      "resetOnExit": {{ openclaw_tailscale_reset_on_exit | lower }}
    }{% endif %}
  }{% set mcp_overrides = {} %}{% for item in openclaw_mcp_servers_defaults %}{% set _ = mcp_overrides.update({(item.name): item}) %}{% endfor %}{% set enabled_defaults = [] %}{% for item in openclaw_mcp_servers_catalog %}{% if mcp_overrides.get(item.name) is defined and (mcp_overrides.get(item.name).enabled | default(false)) %}{% set _ = enabled_defaults.append(item | combine(mcp_overrides.get(item.name)) | combine({'enabled': true})) %}{% endif %}{% endfor %}{% set all_mcp_servers = enabled_defaults + openclaw_mcp_servers %}{% if openclaw_mcp_config_enabled | default(false) and openclaw_mcp_servers_enabled and all_mcp_servers | length > 0 %},
  "mcpServers": {
    {% for server in all_mcp_servers %}
    "{{ server.name }}": {
      "command": "{{ server.command }}",
      "args": {{ server.args | to_json }}{% if server.env is defined and server.env | length > 0 %},
      "env": {{ server.env | to_json }}{% endif %}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  }{% endif %}{% set channels = {} %}{% if openclaw_telegram_enabled %}{% set _ = channels.update({"telegram": {
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": openclaw_telegram_dm_policy,
      "allowFrom": openclaw_telegram_allow_from,
      "groups": openclaw_telegram_groups,
      "configWrites": openclaw_telegram_config_writes
    }}) %}{% endif %}{% if openclaw_slack_enabled %}{% set _ = channels.update({"slack": {
      "enabled": true,
      "botToken": "${SLACK_BOT_TOKEN}",
      "appToken": "${SLACK_APP_TOKEN}",
      "allowBots": openclaw_slack_allow_bots,
      "configWrites": openclaw_slack_config_writes,
      "channels": openclaw_slack_channels
    }}) %}{% endif %}{% if channels | length > 0 %},
  "channels": {{ channels | to_nice_json }}{% endif %}{% if openclaw_telegram_enabled %},
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  }{% endif %}{% if openclaw_himalaya_enabled %},
  "skills": {
    "entries": {
      "himalaya": {
        "enabled": true,
        "config": {
          "replyPolicy": "{{ openclaw_himalaya_reply_policy }}"
        }
      }
    }
  }{% endif %}
}
