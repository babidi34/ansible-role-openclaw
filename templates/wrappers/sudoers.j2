# {{ ansible_managed }}
# Sudoers rules for OpenClaw secure command wrappers
#
# Security notes:
# - Each wrapper is listed explicitly (no wildcards)
# - Only the openclaw user can use these rules
# - Wrappers are owned by root and cannot be modified by openclaw
# - This file must be owned by root:root with mode 0440

{% for wrapper in openclaw_secure_wrappers %}
{{ openclaw_user }} ALL=(root) NOPASSWD: {{ openclaw_secure_wrappers_libexec_dir }}/{{ wrapper.name }}-exec *
{% endfor %}
