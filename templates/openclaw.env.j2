# OpenClaw environment

# Gateway authentication
{% if openclaw_gateway_auth_token | length > 0 %}
{{ openclaw_gateway_auth_env }}="{{ openclaw_gateway_auth_token }}"
{% endif %}

# Telegram
{% if openclaw_telegram_bot_token | length > 0 %}
TELEGRAM_BOT_TOKEN="{{ openclaw_telegram_bot_token }}"
{% endif %}

# Slack (Socket Mode)
{% if openclaw_slack_bot_token | length > 0 %}
SLACK_BOT_TOKEN="{{ openclaw_slack_bot_token }}"
{% endif %}
{% if openclaw_slack_app_token | length > 0 %}
SLACK_APP_TOKEN="{{ openclaw_slack_app_token }}"
{% endif %}

# LLM providers
{% if (openclaw_llm_openai_api_key | default(openclaw_llm_api_key)) | length > 0 %}
OPENAI_API_KEY="{{ openclaw_llm_openai_api_key | default(openclaw_llm_api_key) }}"
{% endif %}
{% if (openclaw_llm_anthropic_api_key | default(openclaw_llm_api_key)) | length > 0 %}
ANTHROPIC_API_KEY="{{ openclaw_llm_anthropic_api_key | default(openclaw_llm_api_key) }}"
{% endif %}
{% if (openclaw_llm_mistral_api_key | default(openclaw_llm_api_key)) | length > 0 %}
MISTRAL_API_KEY="{{ openclaw_llm_mistral_api_key | default(openclaw_llm_api_key) }}"
{% endif %}
{% if (openclaw_llm_google_api_key | default(openclaw_llm_api_key)) | length > 0 %}
GOOGLE_API_KEY="{{ openclaw_llm_google_api_key | default(openclaw_llm_api_key) }}"
{% endif %}
{% if (openclaw_llm_openrouter_api_key | default(openclaw_llm_api_key)) | length > 0 %}
OPENROUTER_API_KEY="{{ openclaw_llm_openrouter_api_key | default(openclaw_llm_api_key) }}"
{% endif %}
{% if openclaw_llm_ollama_base_url | length > 0 %}
OLLAMA_BASE_URL="{{ openclaw_llm_ollama_base_url }}"
{% endif %}

# Web Search (Brave)
{% if openclaw_brave_api_key | length > 0 %}
BRAVE_API_KEY="{{ openclaw_brave_api_key }}"
{% endif %}

# CLI tokens (gh, glab) - injected directly into service environment
{% for item in openclaw_cli_env_vars | default([]) %}
{% if item.token | default('') | length > 0 %}
{{ item.env_var }}="{{ item.token }}"
{% endif %}
{% endfor %}
